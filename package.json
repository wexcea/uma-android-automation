{
    "name": "uma-android-automation",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "start": "expo start",
        "android": "tsx scripts/run-android.ts",
        "android:bundle": "node android/generate-bundle.js",
        "build": "yarn build:doc-index && cd android && ./gradlew assembleRelease",
        "build:clean": "yarn build:doc-index && cd android && ./gradlew --stop && ./gradlew clean && ./gradlew assembleRelease",
        "clean": "cd android && ./gradlew --stop && ./gradlew clean",
        "build:debug": "cd android && ./gradlew assembleDebug",
        "build:debug:clean": "cd android && ./gradlew --stop && ./gradlew clean && ./gradlew assembleDebug",
        "lint": "expo lint",
        "format": "yarn format:tsx && yarn format:kt",
        "format:tsx": "prettier --write \"**/*.tsx\"",
        "format:kt": "cd android && ./gradlew ktlintFormat",
        "update": "yarn install && yarn upgrade-interactive --latest",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:kt": "cd android && ./gradlew test",
        "build:doc-index": "tsx scripts/build-doc-index.ts",
        "perf:nav": "tsx scripts/perf-nav-test.ts"
    },
    "dependencies": {
        "@expo-google-fonts/geist": "^0.4.2",
        "@expo-google-fonts/geist-mono": "^0.4.2",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-community/slider": "5.2.0",
        "@react-native-vector-icons/ionicons": "^13.1.1",
        "@react-navigation/drawer": "^7.7.9",
        "@react-navigation/native": "^7.1.17",
        "@react-navigation/native-stack": "^7.9.0",
        "@rn-primitives/accordion": "^1.2.0",
        "@rn-primitives/alert-dialog": "^1.2.0",
        "@rn-primitives/avatar": "^1.2.0",
        "@rn-primitives/checkbox": "^1.2.0",
        "@rn-primitives/label": "^1.2.0",
        "@rn-primitives/popover": "^1.2.0",
        "@rn-primitives/portal": "^1.3.0",
        "@rn-primitives/select": "^1.2.0",
        "@rn-primitives/separator": "^1.2.0",
        "@rn-primitives/slot": "^1.2.0",
        "@rn-primitives/switch": "^1.2.0",
        "@rn-primitives/tooltip": "^1.2.0",
        "@shopify/flash-list": "2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "expo": "^56.0.0",
        "expo-application": "~56.0.3",
        "expo-blur": "~56.0.3",
        "expo-build-properties": "~56.0.13",
        "expo-clipboard": "~56.0.3",
        "expo-document-picker": "~56.0.4",
        "expo-file-system": "~56.0.7",
        "expo-intent-launcher": "~56.0.4",
        "expo-sharing": "~56.0.12",
        "expo-sqlite": "~56.0.4",
        "expo-status-bar": "~56.0.4",
        "llama.rn": "^0.12.0-rc.9",
        "lucide-react-native": "^0.542.0",
        "nativewind": "4.2.1",
        "react": "19.2.3",
        "react-native": "0.85.3",
        "react-native-boost": "^0.6.2",
        "react-native-draglist": "^3.9.9",
        "react-native-gesture-handler": "~2.31.1",
        "react-native-marked": "^8.0.1",
        "react-native-paper": "^5.14.5",
        "react-native-reanimated": "4.3.1",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.1",
        "react-native-svg": "15.15.4",
        "react-native-url-polyfill": "^2.0.0",
        "react-native-worklets": "0.8.3",
